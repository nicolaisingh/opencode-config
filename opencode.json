{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "rules/context7.md",
    "rules/context-mode.md",
    "rules/gh-grep.md"
  ],
  "mcp": {
    "context-mode": {
      "command": [
        "context-mode"
      ],
      "type": "local"
    },
    "context7": {
      "enabled": false,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh-grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "sequential-thinking": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": false,
      "type": "local"
    }
  },
  "model": "ollama/minimax-m2.7:cloud",
  "permission": {
    "bash": {
      "*": "ask",
      "bd add *": "allow",
      "bd list *": "allow",
      "bd prime *": "allow",
      "bd ready *": "allow"
    },
    "doom_loop": "ask",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "ask",
    "websearch": "ask"
  },
  "plugin": [
    "opencode-beads@0.6.0",
    "opencode-scheduler@1.3.0",
    "context-mode@1.0.75"
    // "@tarquinen/opencode-dcp@3.1.9",
    // "opencode-plugin-openspec@0.1.4"
  ],
  "provider": {
    "ollama": {
      "models": {
        "deepseek-coder-v2:16b": {
          "name": "deepseek-coder-v2:16b"
        },
        "gemma4:26b": {
          "name": "gemma4:26b"
        },
        "glm-4.7-flash:latest": {
          "limit": {
            "context": 200000,
            "output": 131702
          },
          "name": "glm-4.7-flash:latest"
        },
        "glm-5:cloud": {
          "limit": {
            "context": 204800,
            "output": 131702
          },
          "name": "glm-5:cloud"
        },
        "kimi-k2.5:cloud": {
          "limit": {
            "context": 262144,
            "output": 262144
          },
          "name": "kimi-k2.5:cloud"
        },
        "lfm2:latest": {
          "name": "lfm2:latest"
        },
        "minimax-m2.7:cloud": {
          "limit": {
            "context": 204800,
            "output": 131702
          },
          "name": "minimax-m2.7:cloud"
        },
        "qwen3-coder:latest": {
          "name": "qwen3-coder:latest"
        },
        "translategemma:12b": {
          "name": "translategemma:12b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  }
}
